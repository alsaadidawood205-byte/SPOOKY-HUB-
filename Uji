local function copyAvatar(TPlayer)
    if not TPlayer or not TPlayer.Character then
        Notify("خطأ", "اللاعب مو موجود!", 3)
        return
    end

    local lp = LocalPlayer
    local LChar = lp.Character
    local LHumanoid = LChar and LChar:FindFirstChildOfClass("Humanoid")
    local THumanoid = TPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not LHumanoid or not THumanoid then return end

    Notify("نسخ سكنات", "جاري النسخ...", 5)

    task.spawn(function()
        pcall(function()
            local function wearId(id)
                if id and tonumber(id) then
                    Remotes.Wear:InvokeServer(tonumber(id))
                end
            end
            local LDesc = LHumanoid:GetAppliedDescription()
            for _, acc in ipairs(LDesc:GetAccessories(true)) do
                if acc.AssetId then wearId(acc.AssetId); task.wait(0.1) end
            end
            if LDesc.Shirt then wearId(LDesc.Shirt); task.wait(0.1) end
            if LDesc.Pants then wearId(LDesc.Pants); task.wait(0.1) end
            if LDesc.Face then wearId(LDesc.Face); task.wait(0.1) end

            local PDesc = THumanoid:GetAppliedDescription()
            local argsBody = { [1] = {
                PDesc.Torso, PDesc.RightArm, PDesc.LeftArm,
                PDesc.RightLeg, PDesc.LeftLeg, PDesc.Head
            } }
            Remotes.ChangeCharacterBody:InvokeServer(unpack(argsBody))
            task.wait(0.5)

            if PDesc.Shirt then wearId(PDesc.Shirt); task.wait(0.1) end
            if PDesc.Pants then wearId(PDesc.Pants); task.wait(0.1) end
            if PDesc.Face then wearId(PDesc.Face); task.wait(0.1) end
            for _, v in ipairs(PDesc:GetAccessories(true)) do
                if v.AssetId then wearId(v.AssetId); task.wait(0.1) end
            end

            local SkinColor = TPlayer.Character:FindFirstChild("Body Colors")
            if SkinColor then
                Remotes.ChangeBodyColor:FireServer(tostring(SkinColor.HeadColor))
                task.wait(0.1)
            end

            if PDesc.IdleAnimation and tonumber(PDesc.IdleAnimation) then
                wearId(PDesc.IdleAnimation)
                task.wait(0.2)
            end

            local Bag = TPlayer:FindFirstChild("PlayersBag")
            if Bag then
                if Bag:FindFirstChild("RPName") and Bag.RPName.Value ~= "" then
                    Remotes.RPNameText:FireServer("RolePlayName", Bag.RPName.Value); task.wait(0.1)
                end
                if Bag:FindFirstChild("RPBio") and Bag.RPBio.Value ~= "" then
                    Remotes.RPNameText:FireServer("RolePlayBio", Bag.RPBio.Value); task.wait(0.1)
                end
                if Bag:FindFirstChild("RPNameColor") then
                    Remotes.RPNameColor:FireServer("PickingRPNameColor", Bag.RPNameColor.Value); task.wait(0.1)
                end
                if Bag:FindFirstChild("RPBioColor") then
                    Remotes.RPNameColor:FireServer("PickingRPBioColor", Bag.RPBioColor.Value); task.wait(0.1)
                end
            end

            Notify("نسخ سكنات", "تم النسخ بنجاح!", 3)
        end)
    end)
end

CopyTab:AddSection({ "خيارات النسخ" })

CopyTab:AddButton({
    Name = "انسخ سكنة اللاعب المحدد",
    Callback = function()
        if not copyTarget then
            Notify("خطأ", "اختر لاعب اولاً!", 3)
            return
        end
        copyAvatar(copyTarget)
    end
})

CopyTab:AddButton({
    Name = "انسخ سكنة اقرب لاعب",
    Callback = function()
        local lp = LocalPlayer
        local LChar = lp.Character
        if not LChar or not LChar:FindFirstChild("HumanoidRootPart") then return end
        local closest, minDist = nil, math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (LChar.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < minDist then minDist = dist; closest = p end
            end
        end
        if closest then
            copyAvatar(closest)
        else
            Notify("خطأ", "ما في لاعبين قريبين!", 3)
        end
    end
})

CopyTab:AddButton({
    Name = "انسخ سكنة عشوائية",
    Callback = function()
        local others = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then table.insert(others, p) end
        end
        if #others == 0 then
            Notify("خطأ", "ما في لاعبين!", 3)
            return
        end
        copyAvatar(others[math.random(1, #others)])
    end
})
