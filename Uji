local ClearAreaEnabled = false
local ClearAreaOriginalPos = nil
local ClearAreaPhysics = nil
local ClearAreaThread = nil

Tab13:AddToggle({
    Name = "مسح المنطقه 🌪️",
    Default = false,
    Callback = function(Value)
        ClearAreaEnabled = Value
        local lp = LocalPlayer
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        
        if ClearAreaEnabled then
            if not hrp then return end
            ClearAreaOriginalPos = hrp.CFrame
            if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false) end
            
            ClearAreaPhysics = RunService.Heartbeat:Connect(function()
                if not ClearAreaEnabled then return end
                hrp.Velocity = Vector3.new(50000, 50000, 50000)
                hrp.RotVelocity = Vector3.new(50000, 50000, 50000)
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end)
            
            ClearAreaThread = task.spawn(function()
                local angle = 0
                while ClearAreaEnabled do
                    angle = angle + 5
                    local radius = math.random(500, 2000)
                    hrp.CFrame = ClearAreaOriginalPos * CFrame.new(
                        math.sin(angle) * radius,
                        math.random(20, 1000),
                        math.cos(angle) * radius
                    ) * CFrame.Angles(math.random(), math.random(), math.random())
                    task.wait(0.005)
                end
            end)
        else
            if ClearAreaPhysics then ClearAreaPhysics:Disconnect(); ClearAreaPhysics = nil end
            if ClearAreaThread then task.cancel(ClearAreaThread); ClearAreaThread = nil end
            if char then
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") then part.CanCollide = true end
                end
            end
            task.wait(0.05)
            if hrp and ClearAreaOriginalPos then
                hrp.Velocity = Vector3.new(0,0,0); hrp.RotVelocity = Vector3.new(0,0,0)
                hrp.CFrame = ClearAreaOriginalPos * CFrame.new(0, 3, 0)
            end
            if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true); hum.Sit = false end
        end
    end
})

