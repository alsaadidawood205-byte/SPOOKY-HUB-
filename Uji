local SpyTab = Window:MakeTab({ Title = "تجسس", Icon = "rbxassetid://6031094672" })

local currentSpyPlayer = nil
local spyConnection = nil
local autoSpyEnabled = false
local selectedSpyPlayer = nil

local function getSpyPlayerList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(list, plr.Name)
        end
    end
    return list
end

local function refreshSpyDropdown()
    local newList = getSpyPlayerList()
    if spyDropdown then
        pcall(function()
            if spyDropdown.SetOptions then spyDropdown:SetOptions(newList)
            elseif spyDropdown.Set then spyDropdown:Set(newList)
            elseif spyDropdown.Refresh then spyDropdown:Refresh(newList) end
        end)
        if selectedSpyPlayer and not Players:FindFirstChild(selectedSpyPlayer) then
            selectedSpyPlayer = nil
            pcall(function() if spyDropdown.SetValue then spyDropdown:SetValue("") end end)
        end
    end
end

local function startSpy(player)
    if not player or not player.Character then return end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    if spyConnection then
        spyConnection:Disconnect()
        spyConnection = nil
    end
    
    currentSpyPlayer = player
    spyConnection = RunService.Heartbeat:Connect(function()
        if currentSpyPlayer and currentSpyPlayer.Character then
            local hum = currentSpyPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                workspace.CurrentCamera.CameraSubject = hum
            else
                stopSpy()
            end
        else
            stopSpy()
        end
    end)
end

local function stopSpy()
    if spyConnection then
        spyConnection:Disconnect()
        spyConnection = nil
    end
    currentSpyPlayer = nil
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            workspace.CurrentCamera.CameraSubject = hum
        end
    end
end

local spyDropdown = SpyTab:AddDropdown({
    Name = "اختيار لاعب",
    Options = getSpyPlayerList(),
    Default = "",
    Callback = function(value)
        selectedSpyPlayer = value
        print("[Spy] تم اختيار اللاعب: " .. tostring(value))
    end
})

SpyTab:AddButton({
    Name = "تحديث قائمة اللاعبين",
    Callback = function()
        refreshSpyDropdown()
        print("[Spy] تم تحديث قائمة اللاعبين")
    end
})

SpyTab:AddButton({
    Name = "تجسس على المحدد",
    Callback = function()
        if not selectedSpyPlayer then
            Notify("تجسس", "لم يتم اختيار لاعب!", 3)
            return
        end
        local target = Players:FindFirstChild(selectedSpyPlayer)
        if target then
            if autoSpyEnabled then
                autoSpyEnabled = false
                if autoSpyToggle then
                    pcall(function() if autoSpyToggle.Set then autoSpyToggle:Set(false) end end)
                end
            end
            startSpy(target)
            Notify("تجسس", "جاري تجسس على " .. target.Name, 3)
        else
            Notify("خطأ", "اللاعب غير موجود!", 3)
        end
    end
})

SpyTab:AddButton({
    Name = "إيقاف التجسس",
    Callback = function()
        stopSpy()
        autoSpyEnabled = false
        if autoSpyToggle then
            pcall(function() if autoSpyToggle.Set then autoSpyToggle:Set(false) end end)
        end
        Notify("تجسس", "تم إيقاف التجسس", 3)
    end
})

local autoSpyToggle = SpyTab:AddToggle({
    Name = "تجسس تلقائي (تناوب)",
    CurrentValue = false,
    Callback = function(value)
        autoSpyEnabled = value
        if value then
            stopSpy()
            Notify("تجسس", "بدء التجسس التلقائي (يتنقل بين اللاعبين)", 3)
            task.spawn(function()
                while autoSpyEnabled do
                    local allPlayers = Players:GetPlayers()
                    for _, player in pairs(allPlayers) do
                        if not autoSpyEnabled then break end
                        if player ~= LocalPlayer and player.Character then
                            startSpy(player)
                            local waitTime = 5
                            while waitTime > 0 and autoSpyEnabled do
                                task.wait(1)
                                waitTime = waitTime - 1
                            end
                        end
                    end
                    if autoSpyEnabled then task.wait(1) end
                end
                stopSpy()
            end)
        else
            stopSpy()
            Notify("تجسس", "تم إيقاف التجسس التلقائي", 3)
        end
    end
})

Players.PlayerAdded:Connect(refreshSpyDropdown)
Players.PlayerRemoved:Connect(refreshSpyDropdown)

